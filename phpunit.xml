<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true">
    <testsuites>
        <testsuite name="geometry">
            <directory>packages/geometry/tests</directory>
        </testsuite>
        <testsuite name="color">
            <directory>packages/color/tests</directory>
        </testsuite>
        <testsuite name="filters">
            <directory>packages/filters/tests</directory>
        </testsuite>
        <testsuite name="encoding">
            <directory>packages/encoding/tests</directory>
        </testsuite>
        <testsuite name="filesystem">
            <directory>packages/filesystem/tests</directory>
        </testsuite>
        <testsuite name="font-metrics">
            <directory>packages/font-metrics/tests</directory>
        </testsuite>
        <testsuite name="image-metadata">
            <directory>packages/image-metadata/tests</directory>
        </testsuite>
        <testsuite name="xmp">
            <directory>packages/xmp/tests</directory>
        </testsuite>
        <testsuite name="crypt">
            <directory>packages/crypt/tests</directory>
        </testsuite>
        <testsuite name="barcode">
            <directory>packages/barcode/tests</directory>
        </testsuite>
        <testsuite name="font-parser">
            <directory>packages/font-parser/tests</directory>
        </testsuite>
        <testsuite name="conformance">
            <directory>packages/pdf/conformance/tests</directory>
        </testsuite>
        <testsuite name="core">
            <directory>packages/pdf/core/tests</directory>
        </testsuite>
        <testsuite name="writer">
            <directory>packages/pdf/writer/tests</directory>
        </testsuite>
        <testsuite name="reader">
            <directory>packages/pdf/reader/tests</directory>
        </testsuite>
        <testsuite name="toolkit">
            <directory>packages/pdf/toolkit/tests</directory>
        </testsuite>
        <testsuite name="css">
            <directory>packages/css/tests</directory>
        </testsuite>
        <testsuite name="text">
            <directory>packages/text/tests</directory>
        </testsuite>
        <testsuite name="html">
            <directory>packages/html/tests</directory>
        </testsuite>
        <testsuite name="svg">
            <directory>packages/svg/tests</directory>
        </testsuite>
        <testsuite name="html-to-pdf">
            <directory>packages/html-to-pdf/tests</directory>
        </testsuite>
        <testsuite name="svg-to-pdf">
            <directory>packages/svg-to-pdf/tests</directory>
        </testsuite>
        <testsuite name="resource-loader">
            <directory>packages/resource-loader/tests</directory>
        </testsuite>
        <testsuite name="raster">
            <directory>packages/raster/tests</directory>
        </testsuite>
        <testsuite name="paged-media">
            <directory>packages/paged-media/tests</directory>
        </testsuite>
        <testsuite name="wpt-harness">
            <directory>packages/wpt-harness/tests</directory>
        </testsuite>
    </testsuites>
    <coverage>
        <report>
            <clover outputFile="build/coverage/clover.xml"/>
            <html outputDirectory="build/coverage/html"/>
            <text outputFile="php://stdout" showUncoveredFiles="false"/>
        </report>
    </coverage>
    <source>
        <include>
            <directory>packages/pdf/conformance/src</directory>
            <directory>packages/pdf/core/src</directory>
            <directory>packages/pdf/writer/src</directory>
            <directory>packages/pdf/reader/src</directory>
            <directory>packages/pdf/toolkit/src</directory>
            <directory>packages/geometry/src</directory>
            <directory>packages/encoding/src</directory>
            <directory>packages/filesystem/src</directory>
            <directory>packages/font-metrics/src</directory>
            <directory>packages/image-metadata/src</directory>
            <directory>packages/filters/src</directory>
            <directory>packages/color/src</directory>
            <directory>packages/xmp/src</directory>
            <directory>packages/crypt/src</directory>
            <directory>packages/font-parser/src</directory>
            <directory>packages/css/src</directory>
            <directory>packages/text/src</directory>
            <directory>packages/html/src</directory>
            <directory>packages/svg/src</directory>
            <directory>packages/html-to-pdf/src</directory>
            <directory>packages/svg-to-pdf/src</directory>
            <directory>packages/resource-loader/src</directory>
            <directory>packages/raster/src</directory>
            <directory>packages/paged-media/src</directory>
            <directory>packages/wpt-harness/src</directory>
        </include>
    </source>
</phpunit>

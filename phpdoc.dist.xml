<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://www.phpdoc.org/guides"
    xsi:noNamespaceSchemaLocation="https://docs.phpdoc.org/latest/phpdoc.xsd"
>
    <title>phpdftk API Documentation</title>

    <paths>
        <output>build/phpdoc</output>
        <cache>.phpdoc/cache</cache>
    </paths>

    <version number="1.0.0">
        <api>
            <source dsn=".">
                <path>packages/pdf/core/src</path>
                <path>packages/pdf/writer/src</path>
                <path>packages/pdf/reader/src</path>
                <path>packages/pdf/toolkit/src</path>
                <path>packages/pdf/conformance/src</path>
                <path>packages/geometry/src</path>
                <path>packages/color/src</path>
                <path>packages/filters/src</path>
                <path>packages/encoding/src</path>
                <path>packages/font-metrics/src</path>
                <path>packages/font-parser/src</path>
                <path>packages/image-metadata/src</path>
                <path>packages/xmp/src</path>
                <path>packages/crypt/src</path>
            </source>
            <ignore>
                <path>*/tests/*</path>
                <path>*/vendor/*</path>
            </ignore>
            <visibility>public</visibility>
            <visibility>protected</visibility>
            <default-package-name>phpdftk</default-package-name>
        </api>
    </version>

    <setting name="graphs.enabled" value="true"/>
</phpdocumentor>

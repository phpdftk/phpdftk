<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor configVersion="3">
    <title>phpdftk API Documentation</title>

    <parser>
        <target>.phpdoc/cache</target>
        <visibility>public,protected</visibility>
        <default-package-name>phpdftk</default-package-name>
    </parser>

    <transformer>
        <target>build/phpdoc</target>
    </transformer>

    <files>
        <directory>packages/pdf/core/src</directory>
        <directory>packages/pdf/writer/src</directory>
        <directory>packages/pdf/reader/src</directory>
        <directory>packages/pdf/toolkit/src</directory>
        <directory>packages/pdf/conformance/src</directory>
        <directory>packages/geometry/src</directory>
        <directory>packages/color/src</directory>
        <directory>packages/filters/src</directory>
        <directory>packages/encoding/src</directory>
        <directory>packages/font-metrics/src</directory>
        <directory>packages/font-parser/src</directory>
        <directory>packages/image-metadata/src</directory>
        <directory>packages/xmp/src</directory>
        <directory>packages/crypt/src</directory>
        <ignore>
            <path>*/tests/*</path>
            <path>*/vendor/*</path>
        </ignore>
    </files>
</phpdocumentor>

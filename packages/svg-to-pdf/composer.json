{
    "name": "phpdftk/svg-to-pdf",
    "description": "Render SVG to PDF — geometric painter for vector content. Consumes phpdftk/svg, phpdftk/css, phpdftk/text",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "svg",
        "pdf",
        "renderer",
        "svg-to-pdf",
        "vector"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "ext-intl": "*",
        "phpdftk/css": "^1.0",
        "phpdftk/filesystem": "^1.0",
        "phpdftk/pdf-writer": "^1.0",
        "phpdftk/svg": "^1.0",
        "phpdftk/text": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\SvgToPdf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\SvgToPdf\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

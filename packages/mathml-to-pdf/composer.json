{
    "name": "phpdftk/mathml-to-pdf",
    "description": "Render MathML Core to PDF — token + container layout against the existing text shaper. Sibling to phpdftk/svg-to-pdf.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "mathml",
        "pdf",
        "renderer",
        "mathml-to-pdf",
        "math"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "phpdftk/encoding": "^1.0",
        "phpdftk/font-metrics": "^1.0",
        "phpdftk/font-parser": "^1.0",
        "phpdftk/mathml": "^1.0",
        "phpdftk/pdf-writer": "^1.0",
        "phpdftk/text": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\MathmlToPdf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\MathmlToPdf\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

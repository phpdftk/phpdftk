{
    "name": "phpdftk/barcode",
    "description": "Barcode rendering — encoders that produce a 2D bit grid for any drawing target. Zero dependencies; the phpdftk/pdf-writer adapter consumes the bitmap to produce PDF graphics.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "barcode",
        "code128",
        "ean",
        "qr"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\Barcode\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\Barcode\\Tests\\": "tests/"
        }
    }
}

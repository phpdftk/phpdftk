{
    "name": "phpdftk/css",
    "description": "Pure-PHP CSS implementation: Syntax Module 3 tokenizer, Values 4 parser, Selectors 4 engine, Cascade & Inheritance 5 — no external dependencies",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "css",
        "parser",
        "selectors",
        "cascade",
        "values"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "phpdftk/color": "^1.0",
        "phpdftk/geometry": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\Css\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\Css\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * `wpt` — the harness CLI entry point.
 *
 * Subcommands:
 *
 *   wpt run [--root=<path>] [--filter=<glob>]
 *           Walk the corpus under <path> (default
 *           ./vendor-data/wpt), classify each test against the
 *           manifest, emit a summary report to stdout.
 *
 *   wpt classify <test-id> [--root=<path>]
 *           Show how a single test ID would be classified by the
 *           current manifest.
 *
 *   wpt status
 *           Print the most recent harness summary (4A.5).
 *
 *   wpt diff <test-id>
 *           Open the per-test failure artefacts (4A.5).
 */

$autoloadCandidates = [
    __DIR__ . '/../../../vendor/autoload.php',
    __DIR__ . '/../vendor/autoload.php',
];
$autoload = null;
foreach ($autoloadCandidates as $candidate) {
    if (is_file($candidate)) {
        $autoload = $candidate;
        break;
    }
}
if ($autoload === null) {
    fwrite(STDERR, "wpt: could not find autoload.php\n");
    exit(1);
}
require $autoload;

use Phpdftk\WptHarness\BrowserOracle;
use Phpdftk\WptHarness\ConsensusScorer;
use Phpdftk\WptHarness\ConsensusVerdict;
use Phpdftk\WptHarness\CrossBrowserRunner;
use Phpdftk\WptHarness\HarnessRunner;
use Phpdftk\WptHarness\Manifest;
use Phpdftk\WptHarness\Rasteriser;
use Phpdftk\WptHarness\ReportPublisher;
use Phpdftk\WptHarness\Scorer;
use Phpdftk\WptHarness\TestStatus;

$subcommand = $argv[1] ?? 'help';
$args = array_slice($argv, 2);

/**
 * @param  list<string> $args
 * @return array{opts: array<string, string|true>, positional: list<string>}
 */
function parseOptions(array $args): array
{
    $opts = [];
    $positional = [];
    foreach ($args as $arg) {
        if (str_starts_with($arg, '--')) {
            $eq = strpos($arg, '=');
            if ($eq !== false) {
                $opts[substr($arg, 2, $eq - 2)] = substr($arg, $eq + 1);
            } else {
                $opts[substr($arg, 2)] = true;
            }
        } else {
            $positional[] = $arg;
        }
    }
    return ['opts' => $opts, 'positional' => $positional];
}

function manifestDir(): string
{
    return __DIR__ . '/../manifest';
}

function defaultWptRoot(): string
{
    return getcwd() . '/vendor-data/wpt';
}

/**
 * Walk a WPT root for renderable test fixtures. Skips `-ref.*` files
 * (those are the reference renderings, not the tests under test),
 * anything under a `support/` directory (helpers), and anything that
 * doesn't carry a recognised extension. `--include` / `--exclude`
 * globs match against the path RELATIVE to root.
 *
 * `--skip-testharness` filters out tests whose head pulls in WPT's
 * `testharness.js` / `testharnessreport.js` / `testdriver.js` —
 * those rely on JS execution to construct the test (or to even
 * report a result), so they can't be compared as static renders
 * across engines. Scripted reftests (`class="reftest-wait"` +
 * `<link rel="match">`) are not affected because they don't pull
 * the testharness machinery in.
 *
 * @param  list<string> $includes
 * @param  list<string> $excludes
 * @return list<string>
 */
function discoverFixturesForSweep(string $root, array $includes, array $excludes, bool $skipTestHarness = false): array
{
    if (!is_dir($root)) {
        return [];
    }
    $rootReal = realpath($root) ?: $root;
    $rootPrefixLen = strlen($rootReal) + 1;
    $out = [];
    $it = new RecursiveIteratorIterator(new RecursiveDirectoryIterator(
        $rootReal,
        FilesystemIterator::SKIP_DOTS | FilesystemIterator::UNIX_PATHS,
    ));
    foreach ($it as $entry) {
        if (!$entry->isFile()) {
            continue;
        }
        $name = $entry->getFilename();
        if (preg_match('/-ref\.(html?|xht)$/i', $name)) {
            continue;
        }
        if (!preg_match('/\.(html?|xht)$/i', $name)) {
            continue;
        }
        $path = $entry->getPathname();
        if (str_contains($path, '/support/')) {
            continue;
        }
        // WPT `crashtests/` directories AND `*-crash.html` sidecar
        // files are torture tests designed to crash browsers. We
        // include them by default — the renderer clamps pathological
        // length values (LengthResolver::MAX_PX) and caps page count
        // (Renderer::MAX_PAGE_COUNT) so they no longer OOM us, and
        // including them is the only way to track conformity across
        // the WHOLE corpus rather than a curated subset.
        // `--skip-crashtests` opts out when a caller wants a quick
        // sweep that drops the ~1,800 crashtest fixtures.
        if (isset($GLOBALS['cb_sweep_skip_crashtests'])
            && (str_contains($path, '/crashtests/')
                || preg_match('/-crash\.html?$/i', $name))
        ) {
            continue;
        }
        $rel = substr($path, $rootPrefixLen);
        if ($includes !== []) {
            $matched = false;
            foreach ($includes as $glob) {
                // Treat a bare directory name as `<dir>/**` so users
                // can pass `--include=css/css-borders` without
                // remembering the glob syntax.
                $pattern = str_contains($glob, '*') ? $glob : $glob . '/*';
                if (fnmatch($pattern, $rel) || str_starts_with($rel, $glob . '/')) {
                    $matched = true;
                    break;
                }
            }
            if (!$matched) {
                continue;
            }
        }
        if ($excludes !== []) {
            $skip = false;
            foreach ($excludes as $glob) {
                $pattern = str_contains($glob, '*') ? $glob : $glob . '/*';
                if (fnmatch($pattern, $rel) || str_starts_with($rel, $glob . '/')) {
                    $skip = true;
                    break;
                }
            }
            if ($skip) {
                continue;
            }
        }
        if ($skipTestHarness && fixtureUsesTestHarness($path)) {
            continue;
        }
        $out[] = $path;
    }
    sort($out);
    return $out;
}

/**
 * Detect whether a WPT fixture pulls in `testharness.js` (or one of
 * its siblings) — the canonical signal that a test runs JS to
 * construct content / assert results, and so can't be compared as a
 * static render across engines.
 *
 * Read is bounded to the first 16 KB; WPT keeps the harness includes
 * in the `<head>` so this catches every well-formed testharness test
 * without paying the cost of scanning multi-megabyte fixtures.
 */
function fixtureUsesTestHarness(string $path): bool
{
    $head = @file_get_contents($path, false, null, 0, 16 * 1024);
    if ($head === false || $head === '') {
        return false;
    }
    return (bool) preg_match(
        '~<script[^>]*\\bsrc\\s*=\\s*["\'][^"\']*?/(?:testharness(?:report)?|testdriver)(?:-[\w-]+)?\\.js~i',
        $head,
    );
}

/**
 * Truncate a relative path to its first `$depth` path components,
 * used as the aggregation key in `cb-sweep`. A WPT fixture like
 * `css/css-borders/parsing/border-color.html` at depth 2 collapses to
 * `css/css-borders`; at depth 3 it stays under
 * `css/css-borders/parsing`.
 */
function sweepDirKey(string $relPath, int $depth): string
{
    $dir = dirname($relPath);
    if ($dir === '' || $dir === '.') {
        return '(root)';
    }
    $parts = explode('/', $dir);
    if (count($parts) <= $depth) {
        return $dir;
    }
    return implode('/', array_slice($parts, 0, $depth));
}

switch ($subcommand) {
    case 'run': {
        $parsed = parseOptions($args);
        $root = isset($parsed['opts']['root']) && is_string($parsed['opts']['root'])
            ? $parsed['opts']['root']
            : defaultWptRoot();
        $filter = isset($parsed['opts']['filter']) && is_string($parsed['opts']['filter'])
            ? $parsed['opts']['filter']
            : null;
        if (!is_dir($root)) {
            fwrite(STDERR, "wpt run: corpus not found at $root\n");
            fwrite(STDERR, "  Pass --root=<path> or run from the monorepo with vendor-data/wpt populated.\n");
            exit(2);
        }
        $manifest = Manifest::loadFromDirectory(manifestDir());
        $runner = new HarnessRunner($manifest, new Rasteriser(), new Scorer(), $root);
        $results = $runner->run($filter);
        $agg = ReportPublisher::aggregate($results);

        printf("WPT harness — corpus: %s\n", $root);
        if ($filter !== null) {
            printf("Filter: %s\n", $filter);
        }
        printf("\n  Total tests:        %d\n", count($results));
        printf("    Pass:             %d\n", $agg['pass']);
        printf("    Fail:             %d\n", $agg['fail']);
        printf("    Out of scope:     %d\n", $agg['outOfScope']);
        printf("    Pending substr.:  %d\n", $agg['pendingSubstrate']);
        printf("    Skipped:          %d\n", $agg['skipped']);
        printf("    Harness errors:   %d\n", $agg['harnessError']);
        printf("\n  In-scope total:    %d\n", $agg['inScopeTotal']);
        printf("  In-scope pass:     %.2f%%\n", $agg['inScopePassRate'] * 100);

        if (!empty($parsed['opts']['show-fails'])) {
            $fails = array_filter(
                $results,
                static fn($r) => $r->status === TestStatus::Fail,
            );
            usort(
                $fails,
                static fn($a, $b) => $b->diffScore <=> $a->diffScore,
            );
            $limit = is_string($parsed['opts']['show-fails'] ?? null)
                ? (int) $parsed['opts']['show-fails']
                : 25;
            printf("\n  Top %d failures (sorted by diff score):\n", min($limit, count($fails)));
            $i = 0;
            foreach ($fails as $fail) {
                printf(
                    "    %5.2f  %-60s  %s\n",
                    $fail->diffScore,
                    $fail->testId,
                    $fail->reason ?? '',
                );
                if (++$i >= $limit) {
                    break;
                }
            }
        }
        exit(0);
    }
    case 'classify': {
        $parsed = parseOptions($args);
        if (count($parsed['positional']) < 1) {
            fwrite(STDERR, "wpt classify: missing test ID\n");
            fwrite(STDERR, "Usage: wpt classify <test-id>\n");
            exit(2);
        }
        $testId = $parsed['positional'][0];
        $manifest = Manifest::loadFromDirectory(manifestDir());
        $verdict = $manifest->classify($testId);
        if ($verdict === null) {
            printf("%s\n  in-scope (no rule matched)\n", $testId);
            exit(0);
        }
        printf(
            "%s\n  %s\n  reason: %s\n",
            $testId,
            $verdict['status']->value,
            $verdict['reason'],
        );
        if (isset($verdict['phase'])) {
            printf("  phase: %s\n", $verdict['phase']);
        }
        exit(0);
    }
    case 'status':
    case 'diff':
        fwrite(STDERR, "wpt $subcommand: not yet implemented (lands at 4A.5)\n");
        exit(2);

    case 'cross-browser': {
        // Cross-browser PDF oracle: render the requested fixtures
        // through WebKit / Blink / Gecko + ours, score via consensus.
        // See docs/plans/cross-browser-oracle.md.
        $parsed = parseOptions($args);
        // Default to the curated smoke fixtures shipped with the
        // harness so `wpt cross-browser` works without the WPT
        // corpus checked out. Pass `--root=path/to/wpt` to point at
        // the corpus when the curated manifest references real WPT
        // test IDs.
        $root = isset($parsed['opts']['root']) && is_string($parsed['opts']['root'])
            ? $parsed['opts']['root']
            : __DIR__ . '/../curated/smoke';
        $manifestFile = __DIR__ . '/../curated/manifest.json';
        if (!is_file($manifestFile)) {
            fwrite(STDERR, "wpt cross-browser: curated manifest missing at $manifestFile\n");
            exit(2);
        }
        $manifest = json_decode((string) file_get_contents($manifestFile), associative: true);
        if (!is_array($manifest) || !isset($manifest['tests']) || !is_array($manifest['tests'])) {
            fwrite(STDERR, "wpt cross-browser: curated manifest malformed\n");
            exit(2);
        }
        /** @var list<array{id: string, fuzz?: string}> $entries */
        $entries = $manifest['tests'];

        $filter = isset($parsed['opts']['filter']) && is_string($parsed['opts']['filter'])
            ? $parsed['opts']['filter']
            : null;
        if ($filter !== null) {
            $entries = array_values(array_filter(
                $entries,
                static fn(array $e) => fnmatch($filter, $e['id']),
            ));
        }

        // Process-level shard. `--shard=K/N` says "I'm shard K of N,
        // total". K is 1-indexed for ergonomics on the CLI; the
        // bucketing predicate is `(crc32(testId) % N) + 1 === K`.
        // Deterministic on test ID so re-runs across the matrix never
        // shuffle which shard owns which test — important for the
        // browser-cache hit rate when each runner restores its own
        // shard-keyed cache subset. Defaults to "1/1" (no sharding).
        $shardSpec = isset($parsed['opts']['shard']) && is_string($parsed['opts']['shard'])
            ? $parsed['opts']['shard']
            : '1/1';
        if (!preg_match('#^(\d+)/(\d+)$#', $shardSpec, $m)) {
            fwrite(STDERR, "wpt cross-browser: --shard must look like K/N (got: $shardSpec)\n");
            exit(2);
        }
        $shardIndex = (int) $m[1];
        $shardCount = (int) $m[2];
        if ($shardCount < 1 || $shardIndex < 1 || $shardIndex > $shardCount) {
            fwrite(STDERR, "wpt cross-browser: --shard=$shardSpec out of range\n");
            exit(2);
        }
        if ($shardCount > 1) {
            $entries = array_values(array_filter(
                $entries,
                static fn(array $e) => (crc32($e['id']) % $shardCount) + 1 === $shardIndex,
            ));
        }

        // Engine override on the CLI for hosts that can't run one of
        // the three (e.g. Firefox on a Rosetta-bound macOS box). The
        // env var still works; the flag wins when both are set.
        $enginesOpt = isset($parsed['opts']['engines']) && is_string($parsed['opts']['engines'])
            ? array_values(array_filter(array_map('trim', explode(',', $parsed['opts']['engines']))))
            : null;
        if ($enginesOpt !== null) {
            putenv('PHPDFTK_CROSS_BROWSER_ENGINES=' . implode(',', $enginesOpt));
        }

        // --daemon-base routes BrowserOracle through the persistent
        // engine daemons instead of forking node render.mjs per
        // fixture. See docs/plans/cross-browser-container-sweep.md.
        $daemonBase = isset($parsed['opts']['daemon-base']) && is_string($parsed['opts']['daemon-base'])
            ? $parsed['opts']['daemon-base']
            : null;

        // Optional JSON dump of the per-shard result so CI can fold N
        // shards into one PR comment. Schema is documented in
        // scripts/cross-browser/aggregate.php.
        $jsonOut = isset($parsed['opts']['json']) && is_string($parsed['opts']['json'])
            ? $parsed['opts']['json']
            : null;

        if ($entries === []) {
            fwrite(STDERR, "wpt cross-browser: no fixtures match the curated manifest"
                . ($filter !== null ? " + filter $filter" : '')
                . ($shardCount > 1 ? " + shard $shardSpec" : '')
                . "\n");
            // No fixtures in this shard isn't a failure — when the
            // curated subset is small and the matrix is wide some
            // shards legitimately get zero tests. Emit an empty JSON
            // (if requested) and exit 0 so CI sees it as "ran fine,
            // had nothing to do".
            if ($jsonOut !== null) {
                $oracle = new BrowserOracle(daemonBase: $daemonBase);
                $availability = [];
                foreach (['chromium', 'firefox', 'webkit'] as $e) {
                    $availability[$e] = $oracle->isAvailable($e);
                }
                file_put_contents($jsonOut, (string) json_encode([
                    'shard' => ['index' => $shardIndex, 'count' => $shardCount],
                    'engines_available' => $availability,
                    'tallies' => ['pass' => 0, 'fail' => 0, 'skip_disagree' => 0, 'insufficient_engines' => 0, 'harness_error' => 0],
                    'results' => [],
                ], JSON_PRETTY_PRINT));
            }
            exit(0);
        }

        $runner = new CrossBrowserRunner(
            oracle: new BrowserOracle(daemonBase: $daemonBase),
        );

        printf("WPT cross-browser oracle — corpus: %s\n", $root);
        printf("Curated subset: %d fixture%s", count($entries), count($entries) === 1 ? '' : 's');
        if ($shardCount > 1) {
            printf(" (shard %d/%d)", $shardIndex, $shardCount);
        }
        printf("\n\n");

        $tallies = ['pass' => 0, 'fail' => 0, 'skip_disagree' => 0, 'insufficient_engines' => 0, 'harness_error' => 0];
        $resultsRecord = [];
        foreach ($entries as $entry) {
            $testId = $entry['id'];
            $fixturePath = $root . '/' . ltrim($testId, '/');
            $candidates = [$fixturePath, $fixturePath . '.html', $fixturePath . '.htm', $fixturePath . '.xht'];
            $resolved = null;
            foreach ($candidates as $c) {
                if (is_file($c)) {
                    $resolved = $c;
                    break;
                }
            }
            if ($resolved === null) {
                $tallies['harness_error']++;
                printf("  ⚠️  %s — fixture not found\n", $testId);
                $resultsRecord[] = [
                    'testId' => $testId,
                    'verdict' => 'harness_error',
                    'reason' => 'fixture not found',
                    'consensus' => [],
                    'ours' => [],
                    'pairs' => [],
                ];
                continue;
            }
            $budget = match ($entry['fuzz'] ?? 'geometry') {
                'text' => ConsensusScorer::OURS_FUZZ_TEXT,
                default => ConsensusScorer::OURS_FUZZ_GEOMETRY,
            };
            try {
                $result = $runner->runOne($testId, $resolved, $budget);
            } catch (\Throwable $err) {
                $tallies['harness_error']++;
                printf("  ⚠️  %s — %s\n", $testId, $err->getMessage());
                $resultsRecord[] = [
                    'testId' => $testId,
                    'verdict' => 'harness_error',
                    'reason' => $err->getMessage(),
                    'consensus' => [],
                    'ours' => [],
                    'pairs' => [],
                ];
                continue;
            }
            $tallies[$result['verdict']->value]++;
            $icon = match ($result['verdict']) {
                ConsensusVerdict::Pass => '✓',
                ConsensusVerdict::Fail => '✗',
                ConsensusVerdict::SkipDisagree => '·',
                ConsensusVerdict::InsufficientEngines => '?',
            };
            printf(
                "  %s  %-60s  %s\n",
                $icon,
                $testId,
                $result['reason'],
            );
            $resultsRecord[] = [
                'testId' => $testId,
                'verdict' => $result['verdict']->value,
                'reason' => $result['reason'],
                'consensus' => $result['consensus'],
                'ours' => $result['ours'],
                'pairs' => $result['pairs'],
                'engineMissing' => $result['engineMissing'],
                'renderMicros' => $result['renderMicros'],
                'fuzzBudget' => $budget,
            ];
            $runner->cleanupResult($result);
        }
        printf("\nResults:\n");
        printf("  pass:                  %d\n", $tallies['pass']);
        printf("  fail:                  %d\n", $tallies['fail']);
        printf("  skip (browsers disagree): %d\n", $tallies['skip_disagree']);
        printf("  insufficient engines:  %d\n", $tallies['insufficient_engines']);
        printf("  harness errors:        %d\n", $tallies['harness_error']);

        $oracle = new BrowserOracle(daemonBase: $daemonBase);
        $availability = [];
        foreach (['chromium', 'firefox', 'webkit'] as $e) {
            $availability[$e] = $oracle->isAvailable($e);
        }
        $footer = array_map(
            static fn($e) => sprintf('%s=%s', $e, $availability[$e] ? '✓' : '✗'),
            ['chromium', 'firefox', 'webkit'],
        );
        printf("\nEngines available: %s\n", implode('  ', $footer));

        if ($jsonOut !== null) {
            file_put_contents($jsonOut, (string) json_encode([
                'shard' => ['index' => $shardIndex, 'count' => $shardCount],
                'engines_available' => $availability,
                'tallies' => $tallies,
                'results' => $resultsRecord,
            ], JSON_PRETTY_PRINT));
        }

        exit($tallies['fail'] > 0 ? 1 : 0);
    }

    case 'cb-sweep': {
        // Walk a WPT directory tree, render every reftest through our
        // engine plus the available browser engines, and report mean
        // pixel-AE per engine per directory. Where `cross-browser`
        // answers "do the three engines + ours agree on this curated
        // list?", this subcommand answers "across this whole corpus
        // slice, how close does our renderer sit to each engine?" —
        // useful for tracking compliance progress against the real
        // WPT corpus rather than a hand-curated subset.
        $parsed = parseOptions($args);
        $opts = $parsed['opts'];
        $root = isset($opts['root']) && is_string($opts['root'])
            ? $opts['root']
            : defaultWptRoot();
        if (!is_dir($root)) {
            fwrite(STDERR, "wpt cb-sweep: corpus not found at $root\n");
            fwrite(STDERR, "  Pass --root=<path> or vendor WPT at vendor-data/wpt.\n");
            exit(2);
        }

        // --include / --exclude accept comma-separated globs (relative
        // to root). Without --include we walk the entire root, which
        // for a full WPT checkout is tens of thousands of files; pair
        // with --max to bound runtime.
        $includes = isset($opts['include']) && is_string($opts['include'])
            ? array_values(array_filter(array_map('trim', explode(',', $opts['include']))))
            : [];
        $excludes = isset($opts['exclude']) && is_string($opts['exclude'])
            ? array_values(array_filter(array_map('trim', explode(',', $opts['exclude']))))
            : [];
        // --scope=<name> loads a curated directory list from
        // packages/wpt-harness/scope/<name>.json and merges it onto
        // --include. Lets us version-control "these are the WPT
        // top-level directories actually relevant to a PDF renderer"
        // instead of forcing every caller to remember a 30-item
        // glob list. Unknown scope names fail loudly.
        if (isset($opts['scope']) && is_string($opts['scope'])) {
            $scopePath = __DIR__ . '/../scope/' . $opts['scope'] . '.json';
            if (!is_file($scopePath)) {
                fwrite(STDERR, "wpt cb-sweep: --scope={$opts['scope']} not found (looked for $scopePath)\n");
                exit(2);
            }
            $scopeData = json_decode((string) file_get_contents($scopePath), associative: true);
            if (!is_array($scopeData) || !isset($scopeData['include']) || !is_array($scopeData['include'])) {
                fwrite(STDERR, "wpt cb-sweep: --scope={$opts['scope']} malformed (missing `include` array)\n");
                exit(2);
            }
            foreach ($scopeData['include'] as $entry) {
                if (is_string($entry) && $entry !== '' && !in_array($entry, $includes, true)) {
                    $includes[] = $entry;
                }
            }
        }
        $maxFixtures = isset($opts['max']) && (is_string($opts['max']) || is_int($opts['max']))
            ? max(0, (int) $opts['max'])
            : 0;
        $showWorst = isset($opts['show-worst']) && (is_string($opts['show-worst']) || is_int($opts['show-worst']))
            ? max(0, (int) $opts['show-worst'])
            : 0;
        // Aggregation depth — 1 collapses everything under each top-level
        // dir into one row, 2 keeps `css/css-borders` separate from
        // `css/css-box`, etc. Default 2 matches the natural WPT layout.
        $depth = isset($opts['depth']) && (is_string($opts['depth']) || is_int($opts['depth']))
            ? max(1, (int) $opts['depth'])
            : 2;

        $enginesOpt = isset($opts['engines']) && is_string($opts['engines'])
            ? array_values(array_filter(array_map('trim', explode(',', $opts['engines']))))
            : null;
        if ($enginesOpt !== null) {
            putenv('PHPDFTK_CROSS_BROWSER_ENGINES=' . implode(',', $enginesOpt));
        }

        // --daemon-base routes BrowserOracle through the persistent
        // engine daemons. See docs/plans/cross-browser-container-sweep.md.
        $daemonBase = isset($opts['daemon-base']) && is_string($opts['daemon-base'])
            ? $opts['daemon-base']
            : null;

        // Shard predicate matches the `cross-browser` semantics so
        // sweep + curated runs can share the same shard map.
        $shardSpec = isset($opts['shard']) && is_string($opts['shard'])
            ? $opts['shard']
            : '1/1';
        if (!preg_match('#^(\d+)/(\d+)$#', $shardSpec, $shm)) {
            fwrite(STDERR, "wpt cb-sweep: --shard must look like K/N (got: $shardSpec)\n");
            exit(2);
        }
        $shardIndex = (int) $shm[1];
        $shardCount = (int) $shm[2];

        $jsonOut = isset($opts['json']) && is_string($opts['json']) ? $opts['json'] : null;

        // testharness.js tests rely on JS execution to construct
        // content / report results — they don't survive a static
        // PDF-render comparison. `--skip-testharness` drops them at
        // discovery time so the sweep only walks fixtures that can
        // legitimately be scored across engines.
        $skipTestHarness = !empty($opts['skip-testharness']);
        // WPT `crashtests/` and `*-crash.html` are INCLUDED by
        // default — see the discovery helper for the rationale.
        // `--skip-crashtests` opts out for callers who want a quick
        // sweep that drops the ~1,800 adversarial-input fixtures.
        if (!empty($opts['skip-crashtests'])) {
            $GLOBALS['cb_sweep_skip_crashtests'] = true;
        }

        // Discover fixtures. Walks recursively from `$root`; honours
        // `--include` (paths must match at least one) and `--exclude`
        // (path matching any is dropped). The standard WPT layout
        // keeps reference renders alongside the test with the
        // `-ref.*` suffix and helpers under `support/`; we drop both
        // since neither is a renderable test in their own right.
        $fixtures = discoverFixturesForSweep($root, $includes, $excludes, $skipTestHarness);
        if ($shardCount > 1) {
            $fixtures = array_values(array_filter(
                $fixtures,
                static fn(string $p): bool =>
                    (crc32($p) % $shardCount) + 1 === $shardIndex,
            ));
        }
        if ($maxFixtures > 0 && count($fixtures) > $maxFixtures) {
            $fixtures = array_slice($fixtures, 0, $maxFixtures);
        }
        if ($fixtures === []) {
            fwrite(STDERR, "wpt cb-sweep: no fixtures matched\n");
            exit(0);
        }

        $oracle = new BrowserOracle(daemonBase: $daemonBase);
        $availability = [];
        foreach (['chromium', 'firefox', 'webkit'] as $e) {
            $availability[$e] = $oracle->isAvailable($e);
        }
        $resolvedEngines = $enginesOpt !== null
            ? array_values(array_filter(
                $enginesOpt,
                static fn(string $e): bool => $availability[$e] ?? false,
            ))
            : array_keys(array_filter($availability));

        printf("WPT cross-browser sweep — corpus: %s\n", $root);
        if ($includes !== []) {
            printf("  includes: %s\n", implode(', ', $includes));
        }
        if ($excludes !== []) {
            printf("  excludes: %s\n", implode(', ', $excludes));
        }
        printf("  engines:  %s\n", implode(', ', $resolvedEngines) ?: '(none)');
        if ($shardCount > 1) {
            printf("  shard:    %d/%d\n", $shardIndex, $shardCount);
        }
        printf("  fixtures: %d\n\n", count($fixtures));

        $runner = new CrossBrowserRunner(oracle: $oracle);
        // Aggregation buckets keyed by directory (depth-truncated
        // relative to root). Each bucket tracks (count, sums[engine],
        // engineCounts[engine]) so the final mean is sum / engineCount.
        $perDir = [];
        $perFixture = [];
        $oursErrors = 0;
        $tStart = microtime(true);

        foreach ($fixtures as $i => $fixturePath) {
            $relPath = ltrim(str_replace($root, '', $fixturePath), '/');
            $dirKey = sweepDirKey($relPath, $depth);
            if (!isset($perDir[$dirKey])) {
                $perDir[$dirKey] = [
                    'count' => 0,
                    'sums' => [],
                    'engineCounts' => [],
                ];
            }

            try {
                $result = $runner->runOne($relPath, $fixturePath, ConsensusScorer::OURS_FUZZ_GEOMETRY);
            } catch (\Throwable $err) {
                $oursErrors++;
                printf("  ⚠ %-60s  %s\n", $relPath, $err->getMessage());
                continue;
            }
            $perDir[$dirKey]['count']++;
            $aeByEngine = $result['ours'];
            foreach ($aeByEngine as $engine => $ae) {
                $perDir[$dirKey]['sums'][$engine] = ($perDir[$dirKey]['sums'][$engine] ?? 0.0) + $ae;
                $perDir[$dirKey]['engineCounts'][$engine] = ($perDir[$dirKey]['engineCounts'][$engine] ?? 0) + 1;
            }
            $perFixture[] = [
                'path' => $relPath,
                'dir' => $dirKey,
                'ours' => $aeByEngine,
                'engineMissing' => $result['engineMissing'],
            ];
            $runner->cleanupResult($result);

            if ((($i + 1) % 25) === 0) {
                printf(
                    "  ...%4d/%-4d   %.0fs elapsed\n",
                    $i + 1,
                    count($fixtures),
                    microtime(true) - $tStart,
                );
            }
        }

        // Pretty-print the directory roll-up.
        $headerCols = array_merge(['directory', 'fixtures'], $resolvedEngines);
        $dirWidth = max(20, max(array_map('strlen', array_keys($perDir))) + 2);
        $line = sprintf("%-{$dirWidth}s %8s", $headerCols[0], $headerCols[1]);
        foreach ($resolvedEngines as $e) {
            $line .= sprintf(" %10s", $e);
        }
        echo "\n" . str_repeat('=', strlen($line)) . "\n";
        echo $line . "\n";
        echo str_repeat('-', strlen($line)) . "\n";
        ksort($perDir);
        $overallCount = 0;
        $overallSums = [];
        $overallEngineCounts = [];
        foreach ($perDir as $dir => $stat) {
            $overallCount += $stat['count'];
            $row = sprintf("%-{$dirWidth}s %8d", $dir, $stat['count']);
            foreach ($resolvedEngines as $e) {
                $c = $stat['engineCounts'][$e] ?? 0;
                $row .= sprintf(
                    " %10s",
                    $c === 0
                        ? '-'
                        : sprintf('%.2f%%', ($stat['sums'][$e] / $c) * 100),
                );
                $overallSums[$e] = ($overallSums[$e] ?? 0.0) + ($stat['sums'][$e] ?? 0.0);
                $overallEngineCounts[$e] = ($overallEngineCounts[$e] ?? 0) + $c;
            }
            echo $row . "\n";
        }
        echo str_repeat('-', strlen($line)) . "\n";
        $row = sprintf("%-{$dirWidth}s %8d", 'OVERALL', $overallCount);
        foreach ($resolvedEngines as $e) {
            $c = $overallEngineCounts[$e] ?? 0;
            $row .= sprintf(
                " %10s",
                $c === 0
                    ? '-'
                    : sprintf('%.2f%%', ($overallSums[$e] / $c) * 100),
            );
        }
        echo $row . "\n";
        echo str_repeat('=', strlen($line)) . "\n";
        printf("\n  ours-render errors: %d\n", $oursErrors);
        printf("  wall time:          %.0fs\n", microtime(true) - $tStart);

        if ($showWorst > 0) {
            foreach ($resolvedEngines as $engine) {
                $rows = array_values(array_filter(
                    $perFixture,
                    static fn(array $r): bool => isset($r['ours'][$engine]),
                ));
                usort(
                    $rows,
                    static fn(array $a, array $b): int =>
                        $b['ours'][$engine] <=> $a['ours'][$engine],
                );
                $rows = array_slice($rows, 0, $showWorst);
                if ($rows === []) {
                    continue;
                }
                printf("\nTop %d worst fixtures vs %s:\n", count($rows), $engine);
                foreach ($rows as $r) {
                    printf("  %6.2f%%  %s\n", $r['ours'][$engine] * 100, $r['path']);
                }
            }
        }

        if ($jsonOut !== null) {
            $jsonPerDir = [];
            foreach ($perDir as $dir => $stat) {
                $means = [];
                foreach ($resolvedEngines as $e) {
                    $c = $stat['engineCounts'][$e] ?? 0;
                    $means[$e] = $c === 0 ? null : $stat['sums'][$e] / $c;
                }
                $jsonPerDir[$dir] = ['count' => $stat['count'], 'means' => $means];
            }
            $overallMeans = [];
            foreach ($resolvedEngines as $e) {
                $c = $overallEngineCounts[$e] ?? 0;
                $overallMeans[$e] = $c === 0 ? null : $overallSums[$e] / $c;
            }
            file_put_contents($jsonOut, (string) json_encode([
                'root' => $root,
                'includes' => $includes,
                'excludes' => $excludes,
                'engines' => $resolvedEngines,
                'shard' => ['index' => $shardIndex, 'count' => $shardCount],
                'fixtures' => count($fixtures),
                'ours_errors' => $oursErrors,
                'per_directory' => $jsonPerDir,
                'overall' => ['count' => $overallCount, 'means' => $overallMeans],
                'fixtures_detail' => $perFixture,
            ], JSON_PRETTY_PRINT));
        }

        exit(0);
    }

    case 'help':
    case '--help':
    case '-h':
    default:
        echo <<<HELP
Usage: wpt <subcommand> [options]

Subcommands:
  run [--root=<path>] [--filter=<glob>]   Classify the corpus + print summary
  classify <test-id>                       Show verdict for one ID
  cross-browser [--root=<path>] [--filter=<glob>]
                [--shard=K/N] [--engines=<csv>] [--json=<path>]
                [--daemon-base=<url>]
                                           Run the cross-browser PDF oracle
                                           over the curated subset. `--shard`
                                           selects 1/N of the manifest by
                                           deterministic test-ID hash, `--engines`
                                           picks the subset of {chromium,firefox,
                                           webkit} to consult, `--json` writes a
                                           per-shard result dump for the
                                           aggregator. `--daemon-base=<url>`
                                           routes through persistent engine
                                           daemons (`docker compose up -d`)
                                           instead of forking node render.mjs
                                           per fixture — typical value:
                                           `http://127.0.0.1:910` (engines map
                                           to ports 9101/9102/9103).
  cb-sweep [--root=<path>] [--scope=<name>] [--include=<csv-globs>]
           [--exclude=<csv-globs>] [--depth=<N>] [--max=<N>] [--shard=K/N]
           [--engines=<csv>] [--daemon-base=<url>]
           [--skip-testharness] [--skip-crashtests]
           [--show-worst=<N>] [--json=<path>]
                                           Walk the WPT corpus (defaults to the
                                           tree at --root, typically
                                           vendor-data/wpt), render every
                                           non-`-ref` fixture through ours +
                                           each engine, and report mean pixel-AE
                                           per engine, grouped by directory at
                                           the chosen depth (default 2).
                                           `--scope=<name>` loads a curated
                                           top-level directory list from
                                           packages/wpt-harness/scope/<name>.json
                                           (current presets: `rendering`).
                                           `--skip-testharness` drops the
                                           JS-driven testharness.js tests
                                           (which can't be compared as static
                                           renders). `--show-worst=N` lists the
                                           N worst-scoring fixtures per engine.
                                           `--json=<path>` dumps the full
                                           result set (including per-fixture
                                           AE) for downstream slice/dice.
                                           `--daemon-base=<url>` routes through
                                           persistent engine daemons — see
                                           docs/plans/cross-browser-container-sweep.md.
  status                                   Show last run (4A.5)
  diff <test-id>                           Open failure artefacts (4A.5)

See packages/wpt-harness/README.md for full docs.

HELP;
        exit(0);
}

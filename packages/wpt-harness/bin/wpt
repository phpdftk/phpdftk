#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * `wpt` — the harness CLI entry point.
 *
 * Subcommands:
 *
 *   wpt run [--root=<path>] [--filter=<glob>]
 *           Walk the corpus under <path> (default
 *           ./vendor-data/wpt), classify each test against the
 *           manifest, emit a summary report to stdout.
 *
 *   wpt classify <test-id> [--root=<path>]
 *           Show how a single test ID would be classified by the
 *           current manifest.
 *
 *   wpt status
 *           Print the most recent harness summary (4A.5).
 *
 *   wpt diff <test-id>
 *           Open the per-test failure artefacts (4A.5).
 */

$autoloadCandidates = [
    __DIR__ . '/../../../vendor/autoload.php',
    __DIR__ . '/../vendor/autoload.php',
];
$autoload = null;
foreach ($autoloadCandidates as $candidate) {
    if (is_file($candidate)) {
        $autoload = $candidate;
        break;
    }
}
if ($autoload === null) {
    fwrite(STDERR, "wpt: could not find autoload.php\n");
    exit(1);
}
require $autoload;

use Phpdftk\WptHarness\BrowserOracle;
use Phpdftk\WptHarness\ConsensusScorer;
use Phpdftk\WptHarness\ConsensusVerdict;
use Phpdftk\WptHarness\CrossBrowserRunner;
use Phpdftk\WptHarness\HarnessRunner;
use Phpdftk\WptHarness\Manifest;
use Phpdftk\WptHarness\Rasteriser;
use Phpdftk\WptHarness\ReportPublisher;
use Phpdftk\WptHarness\Scorer;
use Phpdftk\WptHarness\TestStatus;

$subcommand = $argv[1] ?? 'help';
$args = array_slice($argv, 2);

function parseOptions(array $args): array
{
    $opts = [];
    $positional = [];
    foreach ($args as $arg) {
        if (str_starts_with($arg, '--')) {
            $eq = strpos($arg, '=');
            if ($eq !== false) {
                $opts[substr($arg, 2, $eq - 2)] = substr($arg, $eq + 1);
            } else {
                $opts[substr($arg, 2)] = true;
            }
        } else {
            $positional[] = $arg;
        }
    }
    return ['opts' => $opts, 'positional' => $positional];
}

function manifestDir(): string
{
    return __DIR__ . '/../manifest';
}

function defaultWptRoot(): string
{
    return getcwd() . '/vendor-data/wpt';
}

switch ($subcommand) {
    case 'run': {
        $parsed = parseOptions($args);
        $root = isset($parsed['opts']['root']) && is_string($parsed['opts']['root'])
            ? $parsed['opts']['root']
            : defaultWptRoot();
        $filter = isset($parsed['opts']['filter']) && is_string($parsed['opts']['filter'])
            ? $parsed['opts']['filter']
            : null;
        if (!is_dir($root)) {
            fwrite(STDERR, "wpt run: corpus not found at $root\n");
            fwrite(STDERR, "  Pass --root=<path> or run from the monorepo with vendor-data/wpt populated.\n");
            exit(2);
        }
        $manifest = Manifest::loadFromDirectory(manifestDir());
        $runner = new HarnessRunner($manifest, new Rasteriser(), new Scorer(), $root);
        $results = $runner->run($filter);
        $agg = ReportPublisher::aggregate($results);

        printf("WPT harness — corpus: %s\n", $root);
        if ($filter !== null) {
            printf("Filter: %s\n", $filter);
        }
        printf("\n  Total tests:        %d\n", count($results));
        printf("    Pass:             %d\n", $agg['pass']);
        printf("    Fail:             %d\n", $agg['fail']);
        printf("    Out of scope:     %d\n", $agg['outOfScope']);
        printf("    Pending substr.:  %d\n", $agg['pendingSubstrate']);
        printf("    Skipped:          %d\n", $agg['skipped']);
        printf("    Harness errors:   %d\n", $agg['harnessError']);
        printf("\n  In-scope total:    %d\n", $agg['inScopeTotal']);
        printf("  In-scope pass:     %.2f%%\n", $agg['inScopePassRate'] * 100);

        if (!empty($parsed['opts']['show-fails'])) {
            $fails = array_filter(
                $results,
                static fn($r) => $r->status === TestStatus::Fail,
            );
            usort(
                $fails,
                static fn($a, $b) => $b->diffScore <=> $a->diffScore,
            );
            $limit = is_string($parsed['opts']['show-fails'] ?? null)
                ? (int)$parsed['opts']['show-fails']
                : 25;
            printf("\n  Top %d failures (sorted by diff score):\n", min($limit, count($fails)));
            $i = 0;
            foreach ($fails as $fail) {
                printf(
                    "    %5.2f  %-60s  %s\n",
                    $fail->diffScore,
                    $fail->testId,
                    $fail->reason ?? '',
                );
                if (++$i >= $limit) {
                    break;
                }
            }
        }
        exit(0);
    }
    case 'classify': {
        $parsed = parseOptions($args);
        if (count($parsed['positional']) < 1) {
            fwrite(STDERR, "wpt classify: missing test ID\n");
            fwrite(STDERR, "Usage: wpt classify <test-id>\n");
            exit(2);
        }
        $testId = $parsed['positional'][0];
        $manifest = Manifest::loadFromDirectory(manifestDir());
        $verdict = $manifest->classify($testId);
        if ($verdict === null) {
            printf("%s\n  in-scope (no rule matched)\n", $testId);
            exit(0);
        }
        printf(
            "%s\n  %s\n  reason: %s\n",
            $testId,
            $verdict['status']->value,
            $verdict['reason'],
        );
        if (isset($verdict['phase'])) {
            printf("  phase: %s\n", $verdict['phase']);
        }
        exit(0);
    }
    case 'status':
    case 'diff':
        fwrite(STDERR, "wpt $subcommand: not yet implemented (lands at 4A.5)\n");
        exit(2);

    case 'cross-browser': {
        // Cross-browser PDF oracle: render the requested fixtures
        // through WebKit / Blink / Gecko + ours, score via consensus.
        // See docs/plans/cross-browser-oracle.md.
        $parsed = parseOptions($args);
        // Default to the curated smoke fixtures shipped with the
        // harness so `wpt cross-browser` works without the WPT
        // corpus checked out. Pass `--root=path/to/wpt` to point at
        // the corpus when the curated manifest references real WPT
        // test IDs.
        $root = isset($parsed['opts']['root']) && is_string($parsed['opts']['root'])
            ? $parsed['opts']['root']
            : __DIR__ . '/../curated/smoke';
        $manifestFile = __DIR__ . '/../curated/manifest.json';
        if (!is_file($manifestFile)) {
            fwrite(STDERR, "wpt cross-browser: curated manifest missing at $manifestFile\n");
            exit(2);
        }
        $manifest = json_decode((string) file_get_contents($manifestFile), associative: true);
        if (!is_array($manifest) || !isset($manifest['tests']) || !is_array($manifest['tests'])) {
            fwrite(STDERR, "wpt cross-browser: curated manifest malformed\n");
            exit(2);
        }
        /** @var list<array{id: string, fuzz?: string}> $entries */
        $entries = $manifest['tests'];

        $filter = isset($parsed['opts']['filter']) && is_string($parsed['opts']['filter'])
            ? $parsed['opts']['filter']
            : null;
        if ($filter !== null) {
            $entries = array_values(array_filter(
                $entries,
                static fn(array $e) => fnmatch($filter, $e['id']),
            ));
        }

        if ($entries === []) {
            fwrite(STDERR, "wpt cross-browser: no fixtures match the curated manifest"
                . ($filter !== null ? " + filter $filter" : '') . "\n");
            exit(2);
        }

        $runner = new CrossBrowserRunner();

        printf("WPT cross-browser oracle — corpus: %s\n", $root);
        printf("Curated subset: %d fixture%s\n\n", count($entries), count($entries) === 1 ? '' : 's');

        $tallies = ['pass' => 0, 'fail' => 0, 'skip_disagree' => 0, 'insufficient_engines' => 0, 'harness_error' => 0];
        foreach ($entries as $entry) {
            $testId = $entry['id'];
            $fixturePath = $root . '/' . ltrim($testId, '/');
            $candidates = [$fixturePath, $fixturePath . '.html', $fixturePath . '.htm', $fixturePath . '.xht'];
            $resolved = null;
            foreach ($candidates as $c) {
                if (is_file($c)) {
                    $resolved = $c;
                    break;
                }
            }
            if ($resolved === null) {
                $tallies['harness_error']++;
                printf("  ⚠️  %s — fixture not found\n", $testId);
                continue;
            }
            $budget = match ($entry['fuzz'] ?? 'geometry') {
                'text' => ConsensusScorer::OURS_FUZZ_TEXT,
                default => ConsensusScorer::OURS_FUZZ_GEOMETRY,
            };
            try {
                $result = $runner->runOne($testId, $resolved, $budget);
            } catch (\Throwable $err) {
                $tallies['harness_error']++;
                printf("  ⚠️  %s — %s\n", $testId, $err->getMessage());
                continue;
            }
            $tallies[$result['verdict']->value]++;
            $icon = match ($result['verdict']) {
                ConsensusVerdict::Pass => '✓',
                ConsensusVerdict::Fail => '✗',
                ConsensusVerdict::SkipDisagree => '·',
                ConsensusVerdict::InsufficientEngines => '?',
            };
            printf(
                "  %s  %-60s  %s\n",
                $icon,
                $testId,
                $result['reason'],
            );
            $runner->cleanupResult($result);
        }
        printf("\nResults:\n");
        printf("  pass:                  %d\n", $tallies['pass']);
        printf("  fail:                  %d\n", $tallies['fail']);
        printf("  skip (browsers disagree): %d\n", $tallies['skip_disagree']);
        printf("  insufficient engines:  %d\n", $tallies['insufficient_engines']);
        printf("  harness errors:        %d\n", $tallies['harness_error']);

        $oracle = new BrowserOracle();
        $availability = array_map(
            static fn($e) => sprintf('%s=%s', $e, $oracle->isAvailable($e) ? '✓' : '✗'),
            ['chromium', 'firefox', 'webkit'],
        );
        printf("\nEngines available: %s\n", implode('  ', $availability));
        exit($tallies['fail'] > 0 ? 1 : 0);
    }

    case 'help':
    case '--help':
    case '-h':
    default:
        echo <<<HELP
Usage: wpt <subcommand> [options]

Subcommands:
  run [--root=<path>] [--filter=<glob>]   Classify the corpus + print summary
  classify <test-id>                       Show verdict for one ID
  cross-browser [--root=<path>] [--filter=<glob>]
                                           Run the cross-browser PDF oracle
                                           over the curated subset.
  status                                   Show last run (4A.5)
  diff <test-id>                           Open failure artefacts (4A.5)

See packages/wpt-harness/README.md for full docs.

HELP;
        exit(0);
}

{
    "name": "phpdftk/font-metrics",
    "description": "AFM metrics for the 14 standard PDF fonts \u2014 no PDF dependency",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "font",
        "metrics",
        "afm",
        "pdf",
        "typography"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\FontMetrics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\FontMetrics\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

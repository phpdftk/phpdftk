{
    "name": "phpdftk/image-metadata",
    "description": "Parse JPEG/PNG/GIF/TIFF/WebP headers to extract dimensions and color space \u2014 no PDF dependency",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "image",
        "metadata",
        "jpeg",
        "png",
        "dimensions"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "phpdftk/filesystem": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\ImageMetadata\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\ImageMetadata\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

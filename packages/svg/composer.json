{
    "name": "phpdftk/svg",
    "description": "Pure-PHP SVG 2 parser: typed tree, full path-grammar, presentation-attribute resolution, optional CSS-inside-SVG via phpdftk/css",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "svg",
        "parser",
        "vector",
        "graphics"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "ext-simplexml": "*",
        "phpdftk/color": "^1.0",
        "phpdftk/css": "^1.0",
        "phpdftk/geometry": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\Svg\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\Svg\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

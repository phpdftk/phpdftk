    "type": "metapackage",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "pdf",
        "php",
        "iso-32000",
        "generator",
        "reader"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "phpdftk/pdf-core": "^1.0",
        "phpdftk/pdf-writer": "^1.0"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }

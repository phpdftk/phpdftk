<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor configVersion="3">
    <title>phpdftk PDF Conformance API</title>
    <parser>
        <target>.phpdoc/cache</target>
        <visibility>public,protected</visibility>
    </parser>
    <transformer>
        <target>build/phpdoc</target>
    </transformer>
    <files>
        <directory>src</directory>
    </files>
</phpdocumentor>

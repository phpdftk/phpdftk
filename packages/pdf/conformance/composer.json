{
    "name": "phpdftk/pdf-conformance",
    "description": "PDF subset conformance validation \u2014 PDF/A, PDF/X, PDF/UA, PDF/E, PDF/VT, PDF/R",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "pdf",
        "conformance",
        "pdf-a",
        "pdf-x",
        "pdf-ua",
        "iso-19005",
        "iso-15930",
        "iso-14289"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "phpdftk/pdf-core": "^1.0 || @dev",
        "phpdftk/xmp": "^1.0 || @dev"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\Pdf\\Conformance\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\Pdf\\Conformance\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

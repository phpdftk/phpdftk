{
    "name": "apprlabs/pdf-writer",
    "description": "PDF writer — serializes the phpdftk object model to spec-compliant PDF bytes",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/apprlabs/phpdftk",
    "keywords": ["pdf", "writer", "generator", "builder"],
    "authors": [
        {"name": "Troy McCabe", "email": "troymccabe@gmail.com"}
    ],
    "support": {
        "issues": "https://github.com/apprlabs/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "apprlabs/pdf-core": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "ApprLabs\\Pdf\\Writer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApprLabs\\Pdf\\Writer\\Tests\\": "tests/"
        }
    }
}

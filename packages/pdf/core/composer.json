{
    "name": "apprlabs/pdf-core",
    "description": "PHP-native OOP mapping of the PDF specification — object model, content streams, document structure",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "apprlabs/geometry": "@dev",
        "apprlabs/encoding": "@dev",
        "apprlabs/font-metrics": "@dev",
        "apprlabs/image-metadata": "@dev",
        "apprlabs/filters": "@dev",
        "apprlabs/color": "@dev",
        "apprlabs/xmp": "@dev",
        "apprlabs/crypt": "@dev",
        "apprlabs/font-parser": "@dev"
    },
    "autoload": {
        "psr-4": {
            "ApprLabs\\Pdf\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApprLabs\\Pdf\\Core\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

{
    "name": "phpdftk/pdf-toolkit",
    "description": "PDF toolkit \u2014 reader-modify-writer pipelines for forms, merging, stamping, extraction, and more",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "pdf",
        "toolkit",
        "merge",
        "stamp",
        "form",
        "extract"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "phpdftk/pdf-core": "^1.0",
        "phpdftk/pdf-reader": "^1.0",
        "phpdftk/xmp": "^1.0",
        "phpdftk/filters": "^1.0",
        "phpdftk/geometry": "^1.0",
        "phpdftk/encoding": "^1.0",
        "phpdftk/image-metadata": "^1.0",
        "phpdftk/font-metrics": "^1.0",
        "phpdftk/crypt": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\Pdf\\Toolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\Pdf\\Toolkit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

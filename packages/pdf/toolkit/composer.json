{
    "name": "apprlabs/pdf-toolkit",
    "description": "PDF toolkit — reader-modify-writer pipelines for forms, merging, stamping, extraction, and more",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/apprlabs/phpdftk",
    "keywords": ["pdf", "toolkit", "merge", "stamp", "form", "extract"],
    "authors": [
        {"name": "Troy McCabe", "email": "troymccabe@gmail.com"}
    ],
    "support": {
        "issues": "https://github.com/apprlabs/phpdftk/issues"
    },
    "require": `{
        "php": "^8.4",
        "apprlabs/pdf-core": "^1.0",
        "apprlabs/pdf-reader": "^1.0",
        "apprlabs/xmp": "^1.0",
        "apprlabs/filters": "^1.0",
        "apprlabs/geometry": "^1.0",
        "apprlabs/encoding": "^1.0",
        "apprlabs/image-metadata": "^1.0",
        "apprlabs/font-metrics": "^1.0",
        "apprlabs/crypt": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "ApprLabs\\Pdf\\Toolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApprLabs\\Pdf\\Toolkit\\Tests\\": "tests/"
        }
    }
}

{
    "name": "phpdftk/pdf-reader",
    "description": "PDF reader \u2014 parses existing PDF files into the phpdftk object model",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "pdf",
        "reader",
        "parser"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "phpdftk/filesystem": "^1.0",
        "phpdftk/pdf-core": "^1.0",
        "phpdftk/filters": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\Pdf\\Reader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\Pdf\\Reader\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

{
    "name": "apprlabs/pdf-reader",
    "description": "PDF reader — parses existing PDF files into the phpdftk object model",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/apprlabs/phpdftk",
    "keywords": ["pdf", "reader", "parser"],
    "authors": [
        {"name": "Troy McCabe", "email": "troymccabe@gmail.com"}
    ],
    "support": {
        "issues": "https://github.com/apprlabs/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "apprlabs/pdf-core": "^1.0",
        "apprlabs/filters": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "ApprLabs\\Pdf\\Reader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApprLabs\\Pdf\\Reader\\Tests\\": "tests/"
        }
    }
}

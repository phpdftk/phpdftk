{
    "name": "phpdftk/font-parser",
    "description": "TrueType, OpenType, and CFF font parser for metric extraction and PDF embedding \u2014 no external dependencies",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "font",
        "truetype",
        "opentype",
        "cff",
        "parser",
        "subsetting"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "phpdftk/filesystem": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\FontParser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\FontParser\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

{
    "name": "phpdftk/phpdftk",
    "description": "PHP-native OOP mapping of the PDF specification for reading, writing, and manipulating PDF files",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "phpdftk/geometry": "@dev",
        "phpdftk/encoding": "@dev",
        "phpdftk/font-metrics": "@dev",
        "phpdftk/image-metadata": "@dev",
        "phpdftk/filters": "@dev",
        "phpdftk/color": "@dev",
        "phpdftk/xmp": "@dev",
        "phpdftk/crypt": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

{
    "name": "phpdftk/filters",
    "description": "FlateDecode, ASCII85, ASCIIHex, RunLength encode/decode \u2014 no PDF dependency",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phpdftk/phpdftk",
    "keywords": [
        "filter",
        "flate",
        "ascii85",
        "compression",
        "decode"
    ],
    "authors": [
        {
            "name": "Troy McCabe",
            "email": "troymccabe@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/phpdftk/phpdftk/issues"
    },
    "require": {
        "php": "^8.4",
        "ext-zlib": "*"
    },
    "autoload": {
        "psr-4": {
            "Phpdftk\\Filters\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\Filters\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}

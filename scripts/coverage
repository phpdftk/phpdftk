#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

mkdir -p build/coverage

# Check for coverage driver
if php -m | grep -q 'pcov'; then
    DRIVER="pcov"
elif php -m | grep -q 'xdebug'; then
    DRIVER="xdebug"
else
    echo "⚠ No coverage driver found. Install pcov or xdebug."
    echo "  macOS: pecl install pcov && echo 'extension=pcov.so' >> $(php --ini | grep 'Loaded Configuration' | awk '{print $NF}')"
    exit 1
fi

echo "Running coverage with $DRIVER driver..."
vendor/bin/phpunit --coverage-clover build/coverage/clover.xml --coverage-text 2>&1 | tee /tmp/coverage_output.txt

# Extract total coverage percentage from text output
COVERAGE=$(grep 'Lines:' /tmp/coverage_output.txt | tail -1 | grep -o '[0-9]*\.[0-9]*%' | head -1 | tr -d '%')

if [ -z "$COVERAGE" ]; then
    COVERAGE=$(grep 'Lines:' /tmp/coverage_output.txt | tail -1 | grep -o '[0-9]*%' | head -1 | tr -d '%')
fi

echo ""
echo "Coverage: ${COVERAGE}%"

# Generate badge
php scripts/generate-badge.php "$COVERAGE" coverage > docs/coverage-badge.svg
echo "Badge written to docs/coverage-badge.svg"

#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

mkdir -p build/coverage

# Check for coverage driver
# Note: grep -q closes the pipe early causing php -m to receive SIGPIPE.
# With pipefail enabled this makes the pipeline fail even when the match is found.
# Capture the module list first to avoid the SIGPIPE / pipefail interaction.
PHP_MODULES=$(php -m 2>/dev/null)
if echo "$PHP_MODULES" | grep -q 'pcov'; then
    DRIVER="pcov"
elif echo "$PHP_MODULES" | grep -q 'xdebug'; then
    DRIVER="xdebug"
else
    echo "⚠ No coverage driver found. Install pcov or xdebug."
    echo "  macOS: pecl install pcov && echo 'extension=pcov.so' >> $(php --ini | grep 'Loaded Configuration' | awk '{print $NF}')"
    exit 1
fi

echo "Running coverage with $DRIVER driver..."
vendor/bin/phpunit --coverage-clover build/coverage/clover.xml --coverage-text 2>&1 | tee /tmp/coverage_output.txt

# Extract total coverage percentage from the summary block.
# The summary line looks like "  Lines:   88.93% (2378/2674)" (leading spaces, Lines: at start).
# Per-class detail lines look like "  Methods: ...   Lines: ..." so we anchor to ^[[:space:]]+Lines:[[:space:]]
COVERAGE=$(grep -E '^[[:space:]]+Lines:[[:space:]]+[0-9]' /tmp/coverage_output.txt \
    | head -1 | grep -o '[0-9]*\.[0-9]*' | head -1)

if [ -z "$COVERAGE" ]; then
    COVERAGE=$(grep -E '^[[:space:]]+Lines:[[:space:]]+[0-9]' /tmp/coverage_output.txt \
        | head -1 | grep -o '[0-9]*' | head -1)
fi

echo ""
echo "Coverage: ${COVERAGE}%"

# Generate badge
mkdir -p docs/generated
php scripts/generate-badge.php "$COVERAGE" coverage > docs/generated/coverage-badge.svg
echo "Badge written to docs/generated/coverage-badge.svg"

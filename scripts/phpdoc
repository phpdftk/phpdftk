#!/usr/bin/env bash
set -euo pipefail

PHPDOC=""
if command -v phpdoc &>/dev/null; then
    PHPDOC="$(command -v phpdoc)"
elif [ -f vendor/bin/phpdoc ]; then
    PHPDOC="$(pwd)/vendor/bin/phpdoc"
else
    echo "phpDocumentor not found. Install via:"
    echo "  brew install phpdocumentor"
    echo "  or: composer require --dev phpdocumentor/phpdocumentor"
    exit 1
fi

if [[ "${1:-}" == "--all" ]]; then
    # Mirror CI: combined monorepo docs + per-package docs collected under
    # build/phpdoc-packages/<name>/ (with a "pdf-" prefix for nested PDF packages).
    # Per-package failures are recorded and rerolled into a non-zero exit at the
    # end so callers (CI) can gate on doc-build health without losing the
    # ability to see all failures in one run.
    failed_pkgs=()
    echo "=== combined ==="
    if ! "$PHPDOC" run; then
        failed_pkgs+=("combined")
    fi

    for pkg in packages/*/phpdoc.dist.xml packages/pdf/*/phpdoc.dist.xml; do
        dir=$(dirname "$pkg")
        name=$(basename "$dir")
        if [[ "$dir" == packages/pdf/* ]]; then
            name="pdf-$name"
        fi
        echo "=== $name ==="
        if ! (cd "$dir" && "$PHPDOC" run); then
            echo "ERROR: phpdoc run failed for $name" >&2
            failed_pkgs+=("$name")
            continue
        fi
        if [ -d "$dir/build/phpdoc" ] && [ -n "$(ls -A "$dir/build/phpdoc" 2>/dev/null)" ]; then
            mkdir -p "build/phpdoc-packages/$name"
            cp -r "$dir/build/phpdoc/." "build/phpdoc-packages/$name/"
        else
            echo "ERROR: $name produced no output in $dir/build/phpdoc" >&2
            failed_pkgs+=("$name (no output)")
        fi
    done
    echo ""
    echo "Combined docs:    build/phpdoc/"
    echo "Per-package docs: build/phpdoc-packages/<name>/"
    if [ ${#failed_pkgs[@]} -gt 0 ]; then
        echo ""
        echo "phpdoc --all failed for: ${failed_pkgs[*]}" >&2
        exit 1
    fi
elif [[ -n "${1:-}" && "${1:-}" != "--"* ]]; then
    # Generate for a specific package directory
    echo "=== $1 ==="
    (cd "$1" && "$PHPDOC" run)
    echo ""
    echo "API docs generated in $1/build/phpdoc/"
else
    # Generate combined monorepo docs (root config)
    "$PHPDOC" run
    echo ""
    echo "API docs generated in build/phpdoc/"
fi

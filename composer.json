{
    "name": "phpdftk/monorepo",
    "description": "Monorepo root — not published to Packagist",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {"type": "path", "url": "packages/pdf/core"},
        {"type": "path", "url": "packages/pdf/writer"},
        {"type": "path", "url": "packages/pdf/reader"},
        {"type": "path", "url": "packages/pdf/toolkit"},
        {"type": "path", "url": "packages/pdf/conformance"},
        {"type": "path", "url": "packages/pdf/all"},
        {"type": "path", "url": "packages/geometry"},
        {"type": "path", "url": "packages/encoding"},
        {"type": "path", "url": "packages/filesystem"},
        {"type": "path", "url": "packages/font-metrics"},
        {"type": "path", "url": "packages/image-metadata"},
        {"type": "path", "url": "packages/filters"},
        {"type": "path", "url": "packages/color"},
        {"type": "path", "url": "packages/xmp"},
        {"type": "path", "url": "packages/crypt"},
        {"type": "path", "url": "packages/font-parser"},
        {"type": "path", "url": "packages/barcode"},
        {"type": "path", "url": "packages/css"},
        {"type": "path", "url": "packages/text"},
        {"type": "path", "url": "packages/html"},
        {"type": "path", "url": "packages/svg"},
        {"type": "path", "url": "packages/html-to-pdf"},
        {"type": "path", "url": "packages/svg-to-pdf"},
        {"type": "path", "url": "packages/resource-loader"},
        {"type": "path", "url": "packages/raster"},
        {"type": "path", "url": "packages/paged-media"},
        {"type": "path", "url": "packages/wpt-harness"}
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "dompdf/dompdf": "^3.0",
        "enshrined/svg-sanitize": "^0.22",
        "friendsofphp/php-cs-fixer": "^3.0",
        "masterminds/html5": "^2.9",
        "meyfa/php-svg": "^0.16",
        "mpdf/mpdf": "^8.2",
        "phpbench/phpbench": "^1.3",
        "phpdftk/barcode": "@dev",
        "phpdftk/color": "@dev",
        "phpdftk/crypt": "@dev",
        "phpdftk/css": "@dev",
        "phpdftk/encoding": "@dev",
        "phpdftk/filters": "@dev",
        "phpdftk/filesystem": "@dev",
        "phpdftk/font-metrics": "@dev",
        "phpdftk/font-parser": "@dev",
        "phpdftk/geometry": "@dev",
        "phpdftk/html": "@dev",
        "phpdftk/html-to-pdf": "@dev",
        "phpdftk/image-metadata": "@dev",
        "phpdftk/pdf": "@dev",
        "phpdftk/pdf-conformance": "@dev",
        "phpdftk/pdf-core": "@dev",
        "phpdftk/pdf-reader": "@dev",
        "phpdftk/pdf-toolkit": "@dev",
        "phpdftk/pdf-writer": "@dev",
        "phpdftk/paged-media": "@dev",
        "phpdftk/raster": "@dev",
        "phpdftk/resource-loader": "@dev",
        "phpdftk/svg": "@dev",
        "phpdftk/svg-to-pdf": "@dev",
        "phpdftk/text": "@dev",
        "phpdftk/wpt-harness": "@dev",
        "phpdftk/xmp": "@dev",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "sabberworm/php-css-parser": "^9.0",
        "setasign/fpdf": "^1.8",
        "smalot/pdfparser": "^2.12",
        "tecnickcom/tcpdf": "^6.7"
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\Benchmarks\\": "benchmarks/",
            "Phpdftk\\Css\\Tests\\": "packages/css/tests/",
            "Phpdftk\\FontParser\\Tests\\": "packages/font-parser/tests/",
            "Phpdftk\\Html\\Tests\\": "packages/html/tests/",
            "Phpdftk\\HtmlToPdf\\Tests\\": "packages/html-to-pdf/tests/",
            "Phpdftk\\Pdf\\Conformance\\": "packages/pdf/conformance/src/",
            "Phpdftk\\PagedMedia\\Tests\\": "packages/paged-media/tests/",
            "Phpdftk\\Pdf\\Conformance\\Tests\\": "packages/pdf/conformance/tests/",
            "Phpdftk\\Raster\\Tests\\": "packages/raster/tests/",
            "Phpdftk\\ResourceLoader\\Tests\\": "packages/resource-loader/tests/",
            "Phpdftk\\Svg\\Tests\\": "packages/svg/tests/",
            "Phpdftk\\SvgToPdf\\Tests\\": "packages/svg-to-pdf/tests/",
            "Phpdftk\\Tests\\Support\\": "tests/Support/",
            "Phpdftk\\Text\\Tests\\": "packages/text/tests/",
            "Phpdftk\\WptHarness\\Tests\\": "packages/wpt-harness/tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpbench/phpbench": true
        }
    },
    "scripts": {
        "test": "@php -d memory_limit=512M vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "lint:fix": "vendor/bin/php-cs-fixer fix",
        "benchmark": "scripts/benchmark",
        "coverage": "scripts/coverage",
        "compliance": "scripts/compliance",
        "examples": "@php examples/run-all.php",
        "phpdoc": "scripts/phpdoc",
        "wpt": "packages/wpt-harness/bin/wpt",
        "wpt:smoke": "packages/wpt-harness/bin/wpt run --root=packages/wpt-harness/fixtures/smoke",
        "cb-sweep:daemon": [
            "docker compose up -d --wait chromium firefox",
            "@php packages/wpt-harness/bin/wpt cb-sweep --daemon-base=http://127.0.0.1:910 --engines=chromium,firefox --scope=rendering --skip-testharness",
            "docker compose down"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

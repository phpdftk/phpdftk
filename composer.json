{
    "name": "phpdftk/monorepo",
    "description": "Monorepo root — not published to Packagist",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {"type": "path", "url": "packages/phpdftk"},
        {"type": "path", "url": "packages/geometry"},
        {"type": "path", "url": "packages/encoding"},
        {"type": "path", "url": "packages/font-metrics"},
        {"type": "path", "url": "packages/image-metadata"},
        {"type": "path", "url": "packages/filters"},
        {"type": "path", "url": "packages/color"},
        {"type": "path", "url": "packages/xmp"},
        {"type": "path", "url": "packages/crypt"}
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpdftk/phpdftk": "@dev",
        "phpdftk/geometry": "@dev",
        "phpdftk/encoding": "@dev",
        "phpdftk/font-metrics": "@dev",
        "phpdftk/image-metadata": "@dev",
        "phpdftk/filters": "@dev",
        "phpdftk/color": "@dev",
        "phpdftk/xmp": "@dev",
        "phpdftk/crypt": "@dev",
        "phpunit/phpunit": "^11.0",
        "phpbench/phpbench": "^1.3",
        "tecnickcom/tcpdf": "^6.7",
        "setasign/fpdf": "^1.8",
        "mpdf/mpdf": "^8.2",
        "dompdf/dompdf": "^3.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdftk\\Benchmarks\\": "benchmarks/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpbench/phpbench": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

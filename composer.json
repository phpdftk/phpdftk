{
    "name": "apprlabs/monorepo",
    "description": "Monorepo root — not published to Packagist",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {"type": "path", "url": "packages/pdf/core"},
        {"type": "path", "url": "packages/pdf/writer"},
        {"type": "path", "url": "packages/pdf/reader"},
        {"type": "path", "url": "packages/pdf/all"},
        {"type": "path", "url": "packages/geometry"},
        {"type": "path", "url": "packages/encoding"},
        {"type": "path", "url": "packages/font-metrics"},
        {"type": "path", "url": "packages/image-metadata"},
        {"type": "path", "url": "packages/filters"},
        {"type": "path", "url": "packages/color"},
        {"type": "path", "url": "packages/xmp"},
        {"type": "path", "url": "packages/crypt"},
        {"type": "path", "url": "packages/font-parser"}
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "apprlabs/color": "@dev",
        "apprlabs/crypt": "@dev",
        "apprlabs/encoding": "@dev",
        "apprlabs/filters": "@dev",
        "apprlabs/font-metrics": "@dev",
        "apprlabs/font-parser": "@dev",
        "apprlabs/geometry": "@dev",
        "apprlabs/image-metadata": "@dev",
        "apprlabs/pdf": "@dev",
        "apprlabs/pdf-core": "@dev",
        "apprlabs/pdf-reader": "@dev",
        "apprlabs/pdf-writer": "@dev",
        "apprlabs/xmp": "@dev",
        "dompdf/dompdf": "^3.0",
        "mpdf/mpdf": "^8.2",
        "phpbench/phpbench": "^1.3",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "setasign/fpdf": "^1.8",
        "smalot/pdfparser": "^2.12",
        "tecnickcom/tcpdf": "^6.7"
    },
    "autoload-dev": {
        "psr-4": {
            "ApprLabs\\Benchmarks\\": "benchmarks/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpbench/phpbench": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

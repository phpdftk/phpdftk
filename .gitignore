# Dependencies
/vendor/
/packages/*/vendor/
/packages/*/*/vendor/

# Composer
composer.phar
/packages/*/composer.lock
/packages/*/*/composer.lock

# PHPUnit
.phpunit.result.cache
/build/coverage/

# PHP CS Fixer
.php-cs-fixer.cache

# Test output
/tests/output/
/tests/.tmp/
/packages/*/tests/output/
/packages/*/*/tests/output/

# PHPBench
.phpbench/

# Generated reports (coverage badge, benchmarks, compliance) — produced by
# scripts/{coverage,benchmark,compliance} for local inspection. CI publishes
# these to dedicated _coverage/_benchmarks/_compliance branches and into the
# docs site, so the in-tree copies aren't a source of truth.
/docs/generated/

# Sample PDFs generated by `composer examples` for the docs site. The
# scripts under examples/ are the source of truth; the .pdf outputs are
# regenerated in CI before the docs build.
/docs/site/public/samples/
/examples/**/*.pdf

# phpDocumentor
.phpdoc/
/build/phpdoc/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Claude
.claude/

# Cross-browser oracle (Node dep tree + browser-render cache)
/scripts/cross-browser/node_modules/
/scripts/cross-browser/package-lock.json
/var/wpt/browser-cache/

